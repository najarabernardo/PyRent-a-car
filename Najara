            print("#####  2 - Exibir Frota (Geral)        #####")
            print("#####  3 - Alterar Dados do Veículo    #####")
            print("#####  4 - Excluir Veículo da Frota    #####")
            print("#####  5 - Relatório: Por Status       #####")
            print("#####  6 - Voltar ao Menu Principal    #####")
            print("############################################")
            opcao_veiculo = input("Opção: ").strip()
            
            if opcao_veiculo == '1':
                print("\n--- [C] Cadastrar Veículo ---")

                if cliente:
                    print(f"\nCliente Encontrado: {cliente['nome']}")
                    cliente['nome'] = input(f"Novo Nome ({cliente['nome']}): ").strip() or cliente['nome']
                    cliente['telefone'] = input(f"Novo Telefone ({cliente['telefone']}): ").strip() or cliente['telefone']

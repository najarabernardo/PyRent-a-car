                if any(v['placa'] == placa for v in veiculos):
                    print("[X] Erro: Já existe um veículo com esta placa na frota!")
                    pausar()
                    continue
                
                modelo = input("Modelo/Carro: ").strip()
                marca = input("Marca: ").strip()
                veiculos.append({"placa": placa, "modelo": modelo, "marca": marca, "status": "Disponível"})
                print("\n[✔] Veículo adicionado à frota!")
                pausar()
                
            elif opcao_veiculo == '2':
                print("\n--- [R] Exibir Frota Total ---")

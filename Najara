                    print("Nenhum veículo cadastrado na frota.")
                else:
                    for v in veiculos:
                        print(f"Placa: {v['placa']} | {v['marca']} {v['modelo']} | Status: {v['status']}")
                pausar()
                
            elif opcao_veiculo == '3':
                print("\n--- [U] Alterar Veículo ---")
                placa_busca = input("Digite a placa do veículo: ").strip().upper()
                veiculo = next((v for v in veiculos if v['placa'] == placa_busca), None)
                
                if veiculo:
                    if veiculo['status'] == 'Alugado':
                        print("[X] Não é possível alterar dados de um veículo alugado no momento.")
                    else:
                        print(f"\nVeículo Encontrado: {veiculo['marca']} {veiculo['modelo']}")
                        veiculo['modelo'] = input(f"Novo Modelo ({veiculo['modelo']}): ").strip() or veiculo['modelo']
                        veiculo['marca'] = input(f"Nova Marca ({veiculo['marca']}): ").strip() or veiculo['marca']
                        print("\n[✔] Dados do veículo atualizados!")
                else:
                    print("[X] Veículo não encontrado.")
                pausar()
                
            elif opcao_veiculo == '4':
                print("\n--- [D] Excluir Veículo ---")
                placa_busca = input("Digite a placa do veículo a ser removido: ").strip().upper()
                veiculo = next((v for v in veiculos if v['placa'] == placa_busca), None)
                
                if veiculo:
                    if veiculo['status'] == 'Alugado':
                        print("[X] Erro: Não é permitido remover um veículo que está alugado!")
                    else:
                        veiculos.remove(veiculo)
                        print("\n[✔] Veículo removido da frota com sucesso!")
                else:
                    print("[X] Veículo não encontrado.")
                pausar()
                
            elif opcao_veiculo == '5':
                print("\n--- [Relatório] Filtrar Frota por Status ---")

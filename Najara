            elif opcao_cliente == '4':
                print("\n--- [D] Excluir Cliente ---")
                cpf_busca = input("Digite o CPF do cliente a ser removido: ").strip()
                cliente = next((c for c in clientes if c['cpf'] == cpf_busca), None)
                
                if cliente:
                    # Impede exclusão se o cliente tiver locação ativa #
                    if any(l['cpf_cliente'] == cpf_busca for l in locacoes):
                        print("[X] Não é possível excluir um cliente com locações pendentes!")
                    else:
                        clientes.remove(cliente)
                        print("\n[✔] Cliente removido com sucesso!")
                else:
                    print("[X] Cliente não encontrado.")
                pausar()
                
            elif opcao_cliente == '5':
                print("\n--- [Relatório] Aniversariantes do Mês ---")
                try:
                    mes_busca = int(input("Digite o número do mês (1 a 12): "))
                    if 1 <= mes_busca <= 12:
                        filtro = [c for c in clientes if c['mes_aniversario'] == mes_busca]
                        if not filtro:
                            print(f"\nNenhum aniversariante no mês {mes_busca}.")
                        else:
                            print(f"\n--- Aniversariantes do Mês {mes_busca} ---")
                            for ani in filtro:
                                print(f"• {ani['nome']} | Tel: {ani['telefone']} | Nasc: {ani['data_nasc_str']}")
                    else:
